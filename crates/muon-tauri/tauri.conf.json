{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/refs/heads/dev/packages/cli/config.schema.json",
  "productName": "Muon SSH",
  "version": "0.1.0",
  "identifier": "com.muon-ssh.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../../frontend run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm --prefix ../../frontend run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Muon SSH",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "externalBin": [],
    "copyright": "",
    "category": "Development",
    "shortDescription": "A modern SSH client built with Rust and Tauri",
    "longDescription": "Muon SSH is a cross-platform SSH/SCP/SFTP client with terminal emulation, dual-pane file browser, port forwarding, and remote system tools.",
    "fileAssociations": [
      {
        "ext": ["muon"],
        "name": "Muon SSH Session",
        "description": "Muon SSH session configuration file",
        "mimeType": "application/x-muon-ssh-session",
        "role": "Editor"
      }
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
